-- 1.1
SELECT s.id AS student_id,
s.full_name,
g.name AS group_name,
s.course,
s.is_active
FROM students s
JOIN groups g ON s.group_id = g.id;

-- 2.1
SELECT g.name AS group_name,
COUNT(s.id) AS cnt_students
FROM groups g
LEFT JOIN students s ON s.group_id = g.id
GROUP BY g.id, g.name;

-- 2.2
SELECT course,
COUNT(*) AS cnt_students,
AVG(avg_grade) AS avg_grade_course
FROM students
GROUP BY course;

-- 2.3
SELECT g.name AS group_name,
MIN(s.avg_grade) AS min_avg,
MAX(s.avg_grade) AS max_avg
FROM students s
JOIN groups g ON s.group_id = g.id
GROUP BY g.id, g.name;

-- 1.2
SELECT s.full_name,
g.name AS group_name,
s.course
FROM students s
JOIN groups g ON s.group_id = g.id
WHERE s.course = 2
ORDER BY g.name, s.full_name;

-- 1.3
SELECT s.full_name,
sub.name AS subject_name,
gr.semester,
gr.grade
FROM grades gr
JOIN students s ON gr.student_id = s.id
JOIN subjects sub ON gr.subject_id = sub.id
ORDER BY s.full_name, sub.name;

-- 3.1
SELECT sub.name AS subject_name,
COUNT(gr.id) AS cnt_grades
FROM subjects sub
LEFT JOIN grades gr ON gr.subject_id = sub.id
GROUP BY sub.id, sub.name;

-- 3.2
SELECT s.full_name,
AVG(gr.grade) AS avg_grade_by_subjects
FROM students s
JOIN grades gr ON gr.student_id = s.id
GROUP BY s.id, s.full_name
ORDER BY avg_grade_by_subjects DESC;

-- 3.3
SELECT g.name AS group_name,
AVG(gr.grade) AS avg_grade_group
FROM groups g
JOIN students s ON s.group_id = g.id
JOIN grades gr ON gr.student_id = s.id
GROUP BY g.id, g.name
ORDER BY avg_grade_group DESC;

-- 4.1
SELECT g.name AS group_name,
COUNT(s.id) AS cnt_students
FROM groups g
LEFT JOIN students s ON s.group_id = g.id
GROUP BY g.id, g.name
HAVING COUNT(s.id) >= 6;

-- 4.2
SELECT sub.name AS subject_name,
COUNT(gr.id) AS cnt_grades
FROM subjects sub
JOIN grades gr ON gr.subject_id = sub.id
GROUP BY sub.id, sub.name
HAVING COUNT(gr.id) >= 8;

-- 4.3
SELECT s.full_name,
AVG(gr.grade) AS avg_grade,
COUNT(gr.id) AS cnt_grades
FROM students s
JOIN grades gr ON gr.student_id = s.id
GROUP BY s.id, s.full_name
HAVING AVG(gr.grade) >= 85 AND COUNT(gr.id) >= 3;
