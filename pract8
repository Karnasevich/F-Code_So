CREATE TABLE groups (
id INTEGER PRIMARY KEY,
name TEXT UNIQUE,
curator TEXT
);

CREATE TABLE students (
id INTEGER PRIMARY KEY,
full_name TEXT,
group_id INTEGER,
course INTEGER,
avg_grade REAL,
is_active INTEGER,
FOREIGN KEY (group_id) REFERENCES groups(id)
);

CREATE TABLE subjects (
id INTEGER PRIMARY KEY,
name TEXT,
hours INTEGER
);

CREATE TABLE grades (
id INTEGER PRIMARY KEY,
student_id INTEGER,
subject_id INTEGER,
grade INTEGER,
semester INTEGER,
FOREIGN KEY (student_id) REFERENCES students(id),
FOREIGN KEY (subject_id) REFERENCES subjects(id)
);

